#!/bin/bash
# Source this file before running terraform:
#   source env.sh
#
# Replace the placeholder values below with your NREC OpenStack credentials.
# Copy this file to env.sh and fill in your actual credentials:
#   cp env.sh.template env.sh
#   nano env.sh

# NREC OpenStack authentication URL
export OS_AUTH_URL="https://identity.api.bgo.nrec.no:5000/v3"

# Your username (typically your email)
export OS_USERNAME="YOUR_USERNAME@your-institution.no"

# Your OpenStack password
export OS_PASSWORD="YOUR_PASSWORD"

# User domain name
export OS_USER_DOMAIN_NAME="dataporten"

# Project name
export OS_PROJECT_NAME="YOUR_PROJECT_NAME"

# Project domain name
export OS_PROJECT_DOMAIN_NAME="dataporten"

# Region
export OS_REGION_NAME="bgo"

# API version
export OS_IDENTITY_API_VERSION=3

# Disable SSL verification (for development/testing)
export OS_INSECURE=true
