#cloud-config

package_update: false
package_upgrade: false

users:
  - name: ${admin_user}
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: render, video, sudo
    shell: /bin/bash
    lock_passwd: false

  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    ssh_authorized_keys:
      - ${ssh_public_key}

chpasswd:
  expire: false
  users:
    - name: ${admin_user}
      password: ${admin_password}
      type: text

write_files:

  - path: /usr/local/lib/hermes-vps/01-desktop.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      export DEBIAN_FRONTEND=noninteractive
      export HOME=/root
      exec > /var/log/hermes-vps/01-desktop.log 2>&1

      apt-get update -qq
      export NEEDRESTART_MODE=l
      mkdir -p /etc/apt/preferences.d
      printf 'Package: firefox*\nPin: release o=*\nPin-Priority: -1\n' > /etc/apt/preferences.d/firefox
      apt-get install -y gnome-shell gnome-session gdm3 gnome-terminal \
        nautilus gnome-control-center gnome-keyring gnome-backgrounds \
        libgl1-mesa-dri xserver-xorg-video-all gnome-session-flashback \
        gnome-calculator gnome-system-monitor gnome-disk-utility \
        eog evince gnome-text-editor baobab gnome-logs gnome-screenshot \
        gnome-shell-extension-desktop-icons-ng dmz-cursor-theme \
        ripgrep ffmpeg xvfb dbus-x11 \
        fonts-liberation fonts-noto-color-emoji \
        fonts-ubuntu fonts-ubuntu-console \
        libnss3 libnspr4 libatk1.0-0t64 libatk-bridge2.0-0t64 libcups2t64 \
        libdrm2 libgbm1 libxkbcommon0 libxcomposite1 libxdamage1 \
        libxrandr2 libxfixes3 libxext6 libasound2t64
      systemctl disable --now snapd 2>/dev/null || true
      systemctl disable --now NetworkManager-wait-online 2>/dev/null || true
      systemctl disable --now ModemManager 2>/dev/null || true
      curl -fsSL https://github.com/TurboVNC/turbovnc/releases/download/3.3/turbovnc_3.3_amd64.deb -o /tmp/turbovnc.deb
      dpkg -i /tmp/turbovnc.deb || apt-get install -f -y
      rm -f /tmp/turbovnc.deb
      export PATH=/opt/TurboVNC/bin:$PATH
      echo 'export PATH=/opt/TurboVNC/bin:$PATH' > /etc/profile.d/turbovnc.sh

      mkdir -p /home/${admin_user}/.vnc
      echo "${admin_password}" | vncpasswd -f > /home/${admin_user}/.vnc/passwd
      chmod 600 /home/${admin_user}/.vnc/passwd
      chown -R ${admin_user}:${admin_user} /home/${admin_user}/.vnc

      cat >> /etc/turbovncserver.conf << 'TVNCCONF'
$wm = "gnome-flashback-metacity";
$userDBus = 1;
TVNCCONF

      echo '${admin_password}' > /home/ubuntu/.vnc-passwd
      chmod 600 /home/ubuntu/.vnc-passwd
      chown ubuntu:ubuntu /home/ubuntu/.vnc-passwd
      echo '${admin_password}' > /home/${admin_user}/.admin-password
      chmod 600 /home/${admin_user}/.admin-password
      chown ${admin_user}:${admin_user} /home/${admin_user}/.admin-password

      nvidia-smi > /dev/null 2>&1 && nvidia-smi --query-gpu=name,driver_version --format=csv,noheader

  - path: /usr/local/lib/hermes-vps/02-ollama.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      export DEBIAN_FRONTEND=noninteractive
      exec > /var/log/hermes-vps/02-ollama.log 2>&1

      curl -fsSL https://ollama.com/install.sh | sh
      systemctl enable --now ollama

      for i in $(seq 1 60); do
        curl -s http://localhost:11434 > /dev/null 2>&1 && break
        sleep 1
      done

      export HOME=/root OLLAMA_HOST=localhost:11434
      ollama pull ${ollama_model} 2>&1 | tee /var/log/hermes-vps/02-ollama-pull.log || true

  - path: /usr/local/lib/hermes-vps/03-hermes.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      exec > /var/log/hermes-vps/03-hermes.log 2>&1
      sudo -u ${admin_user} -H HOME=/home/${admin_user} bash -c 'curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash'
      CHROME=$(ls /home/${admin_user}/.cache/ms-playwright/chromium-*/chrome-linux64/chrome 2>/dev/null | head -1)
      [ -n "$CHROME" ] && ln -sf "$CHROME" /usr/local/bin/chromium

  - path: /usr/local/lib/hermes-vps/04-obsidian.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      export HOME=/root
      exec > /var/log/hermes-vps/04-obsidian.log 2>&1

      curl -fsSL "${obsidian_deb_url}" -o /tmp/obsidian.deb
      apt-get install -y /tmp/obsidian.deb
      rm -f /tmp/obsidian.deb
      mkdir -p /home/${admin_user}/Documents/ObsidianVault
      chown -R ${admin_user}:${admin_user} /home/${admin_user}/Documents/ObsidianVault

runcmd:
  - mkdir -p /var/log/hermes-vps
  - systemctl stop unattended-upgrades 2>/dev/null || true
  - systemctl mask sssd 2>/dev/null || true
  - systemctl mask gnome-remote-desktop 2>/dev/null || true
  - bash /usr/local/lib/hermes-vps/01-desktop.sh
  - bash /usr/local/lib/hermes-vps/04-obsidian.sh
  - bash /usr/local/lib/hermes-vps/02-ollama.sh & bash /usr/local/lib/hermes-vps/03-hermes.sh & wait

final_message: |
  Hermes VPS ready. Start VNC: vncserver :1
  Connect: ssh -L 55901:localhost:5901 -i <key> ubuntu@<ip>, then vncviewer localhost:55901
  VNC password: ${admin_password}
