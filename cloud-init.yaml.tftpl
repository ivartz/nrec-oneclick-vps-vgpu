#cloud-config
# Hermes VPS bootstrap - Ubuntu 24.04 LTS + NVIDIA vGPU, TurboVNC, Ollama, Hermes, Obsidian
# This is a Terraform template; dollar-brace placeholders are filled at apply time.

package_update: true
package_upgrade: false

users:
  - name: ${admin_user}
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: render, video, sudo
    shell: /bin/bash
    lock_passwd: false

  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    ssh_authorized_keys:
      - ${ssh_public_key}

chpasswd:
  expire: false
  list: |
    ${admin_user}:${admin_password}

write_files:

  # Desktop + TurboVNC installation
  - path: /usr/local/lib/hermes-vps/01-desktop.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      export DEBIAN_FRONTEND=noninteractive
      exec > /var/log/hermes-vps/01-desktop.log 2>&1

      apt-get update -qq
      apt-get install -y ubuntu-desktop-minimal turbovnc-server gnome-session-flashback

      mkdir -p /home/${admin_user}/.vnc
      echo "${admin_password}" | vncpasswd -f > /home/${admin_user}/.vnc/passwd
      chmod 600 /home/${admin_user}/.vnc/passwd
      chown -R ${admin_user}:${admin_user} /home/${admin_user}/.vnc
      
      # Configure xstartup for GNOME Classic/Xorg
      cat > /home/${admin_user}/.vnc/xstartup << 'EOF'
#!/bin/sh
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
export TVNC_USERDBUS=1
[ -x /etc/vnc/xstartup ] && exec /etc/vnc/xstartup
[ -r $HOME/.Xresources ] && xrdb $HOME/.Xresources
vncconfig -iconic &
dbus-launch --exit-with-session gnome-session --session=gnome-flashback-metacity &
EOF
      chmod +x /home/${admin_user}/.vnc/xstartup
      chown ${admin_user}:${admin_user} /home/${admin_user}/.vnc/xstartup

      # Verify vGPU if NVIDIA available
      nvidia-smi > /dev/null 2>&1 && nvidia-smi --query-gpu=name,driver_version --format=csv,noheader

  # Ollama installation
  - path: /usr/local/lib/hermes-vps/02-ollama.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      export DEBIAN_FRONTEND=noninteractive
      exec > /var/log/hermes-vps/02-ollama.log 2>&1

      curl -fsSL https://ollama.com/install.sh | sh
      systemctl enable --now ollama

      for i in $(seq 1 60); do
        curl -s http://localhost:11434 > /dev/null 2>&1 && break
        sleep 1
      done

      export HOME=/root OLLAMA_HOST=localhost:11434
      ollama pull ${ollama_model} 2>&1 | tee /var/log/hermes-vps/02-ollama-pull.log || true
      unset HOME OLLAMA_HOST

  # Hermes Desktop installation
  - path: /usr/local/lib/hermes-vps/03-hermes.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      exec > /var/log/hermes-vps/03-hermes.log 2>&1
      curl -fsSL https://hermes-agent.nousresearch.com/install.sh | sh

  # Obsidian installation
  - path: /usr/local/lib/hermes-vps/04-obsidian.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -euo pipefail
      exec > /var/log/hermes-vps/04-obsidian.log 2>&1

      OBS_URL="${obsidian_deb_url}"
      curl -fsSL "$OBS_URL" -o /tmp/obsidian.deb || \
        curl -fsSL "https://github.com/obsidianmd/obsidian-releases/releases/download/v1.7.7/obsidian_1.7.7_amd64.deb" -o /tmp/obsidian.deb

      apt-get install -y /tmp/obsidian.deb
      rm -f /tmp/obsidian.deb
      mkdir -p /home/${admin_user}/Documents/ObsidianVault
      chown -R ${admin_user}:${admin_user} /home/${admin_user}/Documents/ObsidianVault

runcmd:
  - mkdir -p /var/log/hermes-vps
  - bash /usr/local/lib/hermes-vps/01-desktop.sh
  - bash /usr/local/lib/hermes-vps/02-ollama.sh
  - bash /usr/local/lib/hermes-vps/03-hermes.sh
  - bash /usr/local/lib/hermes-vps/04-obsidian.sh

final_message: |
  Hermes VPS bootstrap complete.
  Logs: /var/log/hermes-vps/
  TurboVNC: manually start with 'vncserver :1' after SSH login
  Connect: ssh -L 5901:localhost:5901 -i <private_key> ubuntu@<vm_ip>, then vncviewer localhost:5901
  VNC Password: ${admin_password}
  Ollama API: http://localhost:11434
  Obsidian vault: /home/${admin_user}/Documents/ObsidianVault
